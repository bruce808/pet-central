# Database
DATABASE_URL="postgresql://payjo:payjo@localhost:5432/petcentral?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# OpenSearch
OPENSEARCH_URL="http://localhost:9200"

# S3-compatible storage (MinIO for local dev)
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="pet-central"
S3_REGION="us-east-1"

# JWT
JWT_ACCESS_SECRET="change-me-access-secret-32chars-min"
JWT_REFRESH_SECRET="change-me-refresh-secret-32chars-min"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# AI Providers
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
AI_DEFAULT_PROVIDER="openai"

# Email (SMTP)
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@petcentral.com"

# SMS / OTP
OTP_PROVIDER="console"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# CAPTCHA
CAPTCHA_SECRET_KEY=""
CAPTCHA_SITE_KEY=""

# Application
APP_URL="http://localhost:5000"
API_URL="http://localhost:5100"
AI_ORCHESTRATOR_URL="http://localhost:5200"
NODE_ENV="development"
